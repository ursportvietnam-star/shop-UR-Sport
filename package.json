{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "tsx scripts/check-broken-links.ts && tsx scripts/generate-sitemap.ts",
    "postbuild": "tsx scripts/generate-seo-snapshots.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf dist",
    "ai": "node ai-advisor.mjs",
    "ai:website": "node ai-advisor.mjs --mode=website",
    "ai:blog": "node ai-advisor.mjs --mode=blog",
    "ai:product": "node ai-advisor.mjs --mode=product",
    "ai:export": "node ai-advisor.mjs --mode=full --export",
    "local-ai": "node scripts/local-ai-runner.mjs --mode=automation",
    "local-ai:daily": "node scripts/local-ai-runner.mjs --mode=daily",
    "local-ai:report": "node scripts/local-ai-runner.mjs --mode=automation",
    "local-ai:weekly": "node scripts/local-ai-runner.mjs --mode=weekly",
    "local-ai:product": "node scripts/local-ai-runner.mjs --mode=product",
    "local-ai:all": "node scripts/local-ai-runner.mjs --mode=all"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google/genai": "^1.50.1",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "js-beautify": "^1.15.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.74.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.14.2",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
