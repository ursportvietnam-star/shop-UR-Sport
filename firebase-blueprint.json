{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store items for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "images": { "type": "array" },
        "category": { "type": "string" },
        "colors": { "type": "array" },
        "sizes": { "type": "array" },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "features": { "type": "array" },
        "isNew": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "images", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "shippingAddress", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of sports products"
    },
    "orders": {
      "schema": "Order",
      "description": "User orders"
    }
  }
}
