# GEMINI_API_KEY: Required for Gemini AI API calls.
# CONFIGURE THIS IN THE AI STUDIO SETTINGS MENU (Secrets/Environment Variables).
# DO NOT COMMIT THE ACTUAL KEY TO THE REPOSITORY.
GEMINI_API_KEY=

# OpenAI API. Keep this on the server only. Used by /api/ai/product-seo-fix.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional: set true to generate sitemap URLs from Firestore during build.
# Falls back to static src/data.ts routes when disabled or unavailable.
SITEMAP_USE_FIRESTORE=false
SITE_URL=https://ursport.vn
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_APP_ID=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Newsletter email sending. Keep these values only on the server/deployment environment.
# RESEND_API_KEY is used by /api/send-newsletter.
RESEND_API_KEY=re_br4XYkGi_HW4LJkTdJ84wU7ykVzrPRdSA
NEWSLETTER_FROM_EMAIL="UR Sport <onboarding@resend.dev>"
NEWSLETTER_SEND_TOKEN=ursport-send-2026
