# GEMINI_API_KEY: Server-only key for admin AI tools. Do not expose as VITE_*.
GEMINI_API_KEY=

# Optional: set true to generate sitemap URLs from Firestore during build.
# Falls back to static src/data.ts routes when disabled or unavailable.
SITEMAP_USE_FIRESTORE=false
SITE_URL=https://www.ursport.vn
VITE_SITE_URL=https://www.ursport.vn
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_APP_ID=

# Client-side Firebase config used by Vite during `npm run build`.
# These values must also exist as GitHub repository secrets for GitHub Pages.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Newsletter email sending. Keep these values only on the server/deployment environment.
# RESEND_API_KEY is used by /api/send-newsletter.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL="UR Sport <no-reply@ursport.vn>"
NEWSLETTER_SEND_TOKEN=
