{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|images/|assets/|favicon.svg|sitemap.xml|robots.txt|manifest.webmanifest|sw.js).*)",
      "destination": "/index.html"
    }
  ]
}
