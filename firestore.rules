rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'ursportvietnam@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidOrderCreate() {
      return isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.shippingAddress.fullName is string &&
        request.resource.data.shippingAddress.phone is string &&
        request.resource.data.shippingAddress.address is string;
    }

    function isRatingAggregateUpdate() {
      return isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewsCount']) &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 0 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.reviewsCount is number &&
        request.resource.data.reviewsCount >= resource.data.reviewsCount;
    }

    function isValidReviewCreate() {
      return isSignedIn() &&
        request.resource.data.productId is string &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.userName is string &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.comment is string;
    }

    function isValidNewsletterSubscriber() {
      return request.resource.data.email is string &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') &&
        request.resource.data.status == 'active' &&
        request.resource.data.source is string &&
        request.resource.data.source.size() <= 40 &&
        request.resource.data.keys().hasOnly(['email', 'status', 'source', 'createdAt', 'updatedAt']);
    }

    // Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isRatingAggregateUpdate();
    }

    // Orders: Owner read/write, Admin read/write
    match /orders/{orderId} {
      allow create: if isValidOrderCreate();
      allow read, update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews: Public read, signed-in customers/admins create, admins moderate
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReviewCreate() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Settings used by the storefront, writable only by admins
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog posts: Public read, Admin write
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Media library: Public read, Admin write
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Vouchers: Public read, Admin write
    match /vouchers/{voucherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter subscribers: Visitors can register/re-activate their own email only; admins manage the list
    match /newsletterSubscribers/{subscriberId} {
      allow create: if isAdmin() || isValidNewsletterSubscriber();
      allow update: if isAdmin() || (isValidNewsletterSubscriber() &&
        resource.data.email == request.resource.data.email &&
        resource.data.source == request.resource.data.source);
      allow read, delete: if isAdmin();
    }
    
    // Category SEO rules: public read, admin write
    match /categorySeo/{seoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Private SEO intelligence data: GSC imports and generated reports
    match /seoGscData/{docId} {
      allow read, write: if isAdmin();
    }

    match /seoGscImports/{docId} {
      allow read, write: if isAdmin();
    }

    match /seoAiActions/{docId} {
      allow read, write: if isAdmin();
    }

    match /seoDrafts/{docId} {
      allow read, write: if isAdmin();
    }

    match /seoOpportunities/{docId} {
      allow read, write: if isAdmin();
    }

    match /seoReports/{reportId} {
      allow read, write: if isAdmin();
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    // Users collection for managing customer accounts
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
